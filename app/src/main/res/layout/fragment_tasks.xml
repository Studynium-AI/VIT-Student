<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.TasksFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <!-- Header row with title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Planner"
                android:textColor="?attr/colorOnBackground"
                android:textSize="25sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Segmented toggle: Tasks | Notes -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_group_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_tasks"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="Tasks"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_notes"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="Notes"
                    android:textSize="15sp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content container switching between tasks and notes -->
    <FrameLayout
        android:id="@+id/container_tab_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- TASKS view -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tasks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tv_empty_tasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No upcoming tasks."
            android:textSize="16sp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- NOTES view -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_notes_courses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_empty_notes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No courses found. Sync your data first."
            android:textSize="16sp"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
