<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:colorBackground">

    <!-- Custom Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbar_notes"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?android:colorBackground"
        android:elevation="4dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:srcCompat="@drawable/ic_chevron_left"
            app:tint="?attr/colorOnSurface" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btn_back"
            android:layout_toStartOf="@id/btn_share"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tv_course_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Course Notes"
                android:textColor="?attr/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_course_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorSecondary"
                android:textSize="12sp"
                android:text="Course Code" />
        </LinearLayout>

        <!-- Share button replaces the old camera icon -->
        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Share"
            app:srcCompat="@drawable/ic_share"
            app:tint="?attr/colorOnSurface" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:id="@+id/divider_toolbar"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        android:layout_marginTop="56dp" />

    <!-- Scrollable note content -->
    <ScrollView
        android:id="@+id/scroll_notes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="57dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layout_blocks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:paddingBottom="100dp" />
    </ScrollView>

    <!-- Scrim to dismiss FAB menu when clicking outside (Z-order: placed before buttons so it sits behind them) -->
    <View
        android:id="@+id/fab_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- ==================== FAB area ==================== -->

    <!-- Mini-FAB row: Markdown -->
    <LinearLayout
        android:id="@+id/layout_fab_markdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="252dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Markdown"
            android:textColor="?attr/colorOnSurface"
            android:background="?android:colorBackground"
            android:elevation="4dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_import_markdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Import Markdown"
            app:fabSize="normal"
            app:srcCompat="@drawable/ic_markdown"
            app:tint="@android:color/white"
            app:backgroundTint="?attr/colorPrimary"
            app:elevation="6dp"
            app:maxImageSize="24dp" />
    </LinearLayout>

    <!-- Mini-FAB row: Gallery -->
    <LinearLayout
        android:id="@+id/layout_fab_gallery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="180dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gallery"
            android:textColor="?attr/colorOnSurface"
            android:background="?android:colorBackground"
            android:elevation="4dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_gallery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Import from Gallery"
            app:fabSize="normal"
            app:srcCompat="@drawable/ic_attachment"
            app:tint="@android:color/white"
            app:backgroundTint="?attr/colorPrimary"
            app:elevation="6dp"
            app:maxImageSize="24dp" />
    </LinearLayout>

    <!-- Mini-FAB row: Camera -->
    <LinearLayout
        android:id="@+id/layout_fab_camera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera"
            android:textColor="?attr/colorOnSurface"
            android:background="?android:colorBackground"
            android:elevation="4dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_camera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Capture from Camera"
            app:fabSize="normal"
            app:srcCompat="@drawable/ic_camera"
            app:tint="@android:color/white"
            app:backgroundTint="?attr/colorPrimary"
            app:elevation="6dp"
            app:maxImageSize="24dp" />
    </LinearLayout>

    <!-- Main FAB: Rounded square + button -->
    <ImageButton
        android:id="@+id/fab_add"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_fab_rounded_square"
        android:contentDescription="Add content"
        android:elevation="8dp"
        android:padding="16dp"
        app:srcCompat="@drawable/ic_add"
        app:tint="@android:color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
