<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".VTOP"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VTOP.SplashScreen"
        tools:ignore="AllowBackup"
        tools:targetApi="s">

        <activity
            android:name=".activities.LauncherActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".activities.LoginActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.VTOP.Login"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".activities.MainActivity"
            android:configChanges="orientation|screenSize"
            android:theme="@style/Theme.VTOP"
            android:windowSoftInputMode="adjustPan"
            android:exported="true" />
        <activity
            android:name=".activities.PermissionsActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.VTOP"
            android:exported="false" />
        <activity
            android:name=".activities.WebViewActivity"
            android:theme="@style/Theme.VTOP"
            android:exported="false" />

        <service
            android:name=".services.VTOPService"
            android:description="@string/vtop_service_description"
            android:foregroundServiceType="dataSync"
            android:label="VTOP" />
            
        <service
            android:name=".lockscreen.LockScreenService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="Displays schedule over lock screen" />
        </service>
        
        <activity
            android:name=".lockscreen.LockScreenActivity"
            android:showWhenLocked="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.VTOP.LockScreen"
            android:launchMode="singleTop"
            android:exported="false" />

        <activity
            android:name=".activities.CourseNotesActivity"
            android:showWhenLocked="true"
            android:theme="@style/Theme.VTOP"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name=".activities.PhotoViewerActivity"
            android:showWhenLocked="true"
            android:theme="@style/Theme.VTOP"
            android:exported="false" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
        <meta-data
            android:name="google_analytics_automatic_screen_reporting_enabled"
            android:value="false" />

        <receiver
            android:name=".lockscreen.LockScreenAdminReceiver"
            android:label="Lock Screen UI Admin"
            android:description="@string/device_admin_description"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_rules" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <receiver android:name=".receivers.ExamNotificationReceiver" />
        <receiver android:name=".receivers.TimetableNotificationReceiver" />
        <receiver android:name=".receivers.TaskNotificationReceiver" android:exported="false">
            <intent-filter>
                <action android:name="tk.therealsuji.vtopchennai.ACTION_TASK_REMINDER" />
                <action android:name="tk.therealsuji.vtopchennai.ACTION_TASK_COMPLETE" />
            </intent-filter>
        </receiver>
        <receiver android:name=".receivers.ScheduleAlarmReceiver" android:exported="false">
            <intent-filter>
                <action android:name="tk.therealsuji.vtopchennai.ACTION_SCHEDULE_START" />
                <action android:name="tk.therealsuji.vtopchennai.ACTION_SCHEDULE_STOP" />
            </intent-filter>
        </receiver>
        <receiver
            android:name=".receivers.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>